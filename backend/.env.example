# LLM Provider: deepseek / anthropic / minimax
LLM_PROVIDER=deepseek

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_CHAT_MODEL=deepseek-chat

# Anthropic (optional, alternative provider)
ANTHROPIC_API_KEY=

# MiniMax (optional, alternative provider)
MINIMAX_API_KEY=
MINIMAX_CHAT_MODEL=abab6.5s-chat
MINIMAX_API_BASE_URL=https://api.minimaxi.com

# OpenAI (required for vector embeddings)
OPENAI_API_KEY=

# JWT
JWT_SECRET=dev-secret-change-in-production

# Database
DATABASE_PATH=./data/memory.db
